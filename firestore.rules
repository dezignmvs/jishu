rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Contact form submissions
    match /dmx/{document} {
      allow create: if true; // Anyone can submit contact messages from the website
      allow read, delete: if true; // Admin console can view and delete messages
    }
    
    // Program courses and workshops database
    match /programData/{document} {
      allow read: if true; // Anyone can read programs on the gallery view
      allow write: if true; // Admin console can create, update, and delete programs
    }

    // Blog database
    match /blogData/{document} {
      allow read: if true;
      allow write: if true;
    }
  }
}
